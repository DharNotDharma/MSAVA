@page "/register"
@inject HttpClient Http
@inject NavigationManager Nav

<h3>Register</h3>
<EditForm Model="registerModel" OnValidSubmit="RegisterUser">
    <InputText @bind-Value="registerModel.Username" placeholder="Username" />
    <InputText @bind-Value="registerModel.Password" placeholder="Password" type="password" />
    <InputText @bind-Value="registerModel.InviteCode" placeholder="Invite Code" />
    <button type="submit">Register</button>
</EditForm>
@if (!string.IsNullOrEmpty(error))
{
    <div style="color:red">@error</div>
}

@code {
    RegisterModel registerModel = new();
    string error;

    async Task RegisterUser()
    {
        // Map property names to match API (all lowercase)
        var body = new
        {
            username = registerModel.Username,
            password = registerModel.Password,
            inviteCode = registerModel.InviteCode
        };

        var resp = await Http.PostAsJsonAsync("api/auth/register", body);
        if (resp.IsSuccessStatusCode)
            Nav.NavigateTo("/login");
        else
        {
            var content = await resp.Content.ReadAsStringAsync();
            error = $"Registration failed: {resp.StatusCode} - {content}";
        }
    }

    class RegisterModel
    {
        public string Username { get; set; }
        public string Password { get; set; }
        public string InviteCode { get; set; }
    }
}
